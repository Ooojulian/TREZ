// Ejemplo 7: Control de Flujo
// Condicionales y bucles

let x = 10;

if x > 5 {
  1;
} else {
  0;
}

// While loop
let counter = 0;
while counter < 3 {
  counter;
  let counter = counter + 1;
}

// Condicional anidado
let score = 85;
if score >= 90 {
  "A";
} else {
  if score >= 80 {
    "B";
  } else {
    "C";
  }
}
