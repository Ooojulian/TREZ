// test_runtime_errors.trez — errores de ejecucion esperados
// Ejecutar uno a la vez descomentando la linea que se quiere probar.
// Cada uno debe terminar con un mensaje de error claro.

// ── 1. Variable no definida ───────────────────────────────────────────────
// variable_inexistente;

// ── 2. Division por cero ──────────────────────────────────────────────────
// let x = 10 / 0;

// ── 3. dot() con dimensiones incompatibles ────────────────────────────────
let a = [1, 2, 3];
let b = [4, 5];
let err = dot(a, b);

