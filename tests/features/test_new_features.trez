mostrar("-- Anidadas --");
let matrix = [[1, 2], [3, 4], [5, 6]];
mostrar(matrix[1]);
mostrar(matrix[1][0]);

// ── 7. Diccionarios ───────────────────────────────────────────────────────
mostrar("-- Diccionarios --");
let persona = {nombre: "Julian", edad: 22, activo: true};
mostrar(persona["nombre"]);
mostrar(persona["edad"]);
mostrar(keys(persona));
mostrar(values(persona));
let persona2 = persona.set("edad", 23);
mostrar(persona2["edad"]);
mostrar(persona.has("activo"));

// ── 8. Queue ─────────────────────────────────────────────────────────────
mostrar("-- Queue --");
let q = Queue();
let q = q.enqueue(1);
let q = q.enqueue(2);
let q = q.enqueue(3);
mostrar(q.size());
mostrar(q.peek());
mostrar(q.toList());
let resultado = q.dequeue();
let val = resultado[0];
let q   = resultado[1];
mostrar(val);
mostrar(q.toList());

// ── 9. Stack ─────────────────────────────────────────────────────────────
mostrar("-- Stack --");
let s = Stack();
let s = s.push(10);
let s = s.push(20);
let s = s.push(30);
mostrar(s.size());
mostrar(s.peek());
let r = s.pop();
mostrar(r[0]);
mostrar(r[1].toList());

// ── 10. Funciones de orden con listas ────────────────────────────────────
mostrar("-- Func + listas --");
func suma_lista(lst) {
    if (len(lst) == 0) { return 0; }
    return head(lst) + suma_lista(tail(lst));
}
mostrar(suma_lista([1, 2, 3, 4, 5]));  // 15

func map_doble(lst) {
    if (len(lst) == 0) { return []; }
    return append(map_doble(tail(lst)), head(lst) * 2);
}
mostrar(map_doble([1, 2, 3]));   // [6, 4, 2] reversed pero correcto

// ── 11. While con comparadores ───────────────────────────────────────────
mostrar("-- While --");
let cnt = 0;
let acc = 0;
while (cnt < 5) {
    let acc = acc + cnt;
    let cnt = cnt + 1;
}
mostrar(cnt);
mostrar(acc);

