// ── 1. Funciones recursivas ───────────────────────────────────────────────
func factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

func fibonacci(n) {
    if (n <= 0) { return 0; }
    if (n == 1) { return 1; }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

mostrar("-- Recursion --");
mostrar(factorial(6));    // 720
mostrar(fibonacci(10));   // 55

// ── 2. Condicionales encadenados (else if) ────────────────────────────────
func clasificar(x) {
    if (x < 0) {
        return "negativo";
    } else if (x == 0) {
        return "cero";
    } else {
        return "positivo";
    }
}

mostrar("-- Condicionales --");
mostrar(clasificar(-5));
mostrar(clasificar(0));
mostrar(clasificar(7));

// ── 3. NOT, &&, || ───────────────────────────────────────────────────────
let a = true;
let b = false;
mostrar("-- Logica --");
mostrar(not b);
mostrar(a && b);
mostrar(a || b);

// ── 4. For loop + range ───────────────────────────────────────────────────
mostrar("-- For + range --");
let suma = 0;
for i in range(5) {
    let suma = suma + i;
}
// Acumular desde afuera requiere while; for crea scope propio.
// Demostramos iteración con mostrar:
for x in [10, 20, 30] {
    mostrar(x);
}

// ── 5. Listas — métodos y acceso ─────────────────────────────────────────
mostrar("-- Listas --");
let nums = [3, 1, 4, 1, 5];
mostrar(len(nums));
mostrar(nums[2]);
mostrar(head(nums));
mostrar(tail(nums));
let nums2 = append(nums, 9);
mostrar(nums2);
mostrar(nums2.reverse());
mostrar(nums2.slice(1, 4));
mostrar(nums.contains(4));

