// test_control_flow.trez — condicionales, ciclos, logica booleana

// ── if / else if / else ───────────────────────────────────────────────────
func signo(x) {
    if (x > 0)      { return 1; }
    else if (x < 0) { return -1; }
    else            { return 0; }
}
mostrar(signo(42));   // 1
mostrar(signo(-7));   // -1
mostrar(signo(0));    // 0

func categoria_nota(n) {
    if (n >= 90)      { return "A"; }
    else if (n >= 80) { return "B"; }
    else if (n >= 70) { return "C"; }
    else if (n >= 60) { return "D"; }
    else              { return "F"; }
}
mostrar(categoria_nota(95));  // A
mostrar(categoria_nota(83));  // B
mostrar(categoria_nota(71));  // C
mostrar(categoria_nota(61));  // D
mostrar(categoria_nota(45));  // F

// ── Logica booleana: not, &&, || ─────────────────────────────────────────
mostrar(not true);           // False
mostrar(not false);          // True
mostrar(true && true);       // True
mostrar(true && false);      // False
mostrar(false || true);      // True
mostrar(false || false);     // False
mostrar(not (true && false)); // True

// Short-circuit
func siempre_falla() {
    return 1 / 0;
}
mostrar(false && false);   // False — segundo no se evalua
mostrar(true || true);     // True  — segundo no se evalua

// ── Comparadores ──────────────────────────────────────────────────────────
mostrar(3 == 3);    // True
mostrar(3 != 4);    // True
mostrar(5 > 3);     // True
mostrar(5 >= 5);    // True
mostrar(2 < 10);    // True
mostrar(2 <= 1);    // False

// ── while ─────────────────────────────────────────────────────────────────
let i = 0;
let total = 0;
while (i < 10) {
    let total = total + i;
    let i = i + 1;
}
mostrar(i);      // 10
mostrar(total);  // 45

// Countdown
let c = 5;
while (c > 0) {
    mostrar(c);
    let c = c - 1;
}
// 5 4 3 2 1

// ── for in lista ──────────────────────────────────────────────────────────
for item in [10, 20, 30, 40] {
    mostrar(item);
}
// 10 20 30 40

// ── for in range ──────────────────────────────────────────────────────────
for n in range(5) {
    mostrar(n);
}
// 0 1 2 3 4

for n in range(2, 8) {
    mostrar(n);
}
// 2 3 4 5 6 7

// ── for sobre string ─────────────────────────────────────────────────────
for letra in "TREZ" {
    mostrar(letra);
}
// T R E Z

// ── Condicional dentro de for ────────────────────────────────────────────
for v in [1, -2, 3, -4, 5] {
    if (v > 0) { mostrar(v); }
}
// 1 3 5
