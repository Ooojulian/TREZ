// Prueba de Función de Pérdida (MSE)
let predicciones = [0.1, 0.9, 0.4];
let reales       = [0.0, 1.0, 0.5];

// Error de red
let error = mse(reales, predicciones);
let gradientes = mse_grad(reales, predicciones);

error;
gradientes;

// Suposición de entrenamiento: Actualización de pesos
// W_nuevo = W_viejo - lr * gradiente
let pesos = [0.5, 0.5, 0.5];
let pesos_nuevos = pesos - 0.1 * gradientes;

pesos_nuevos;
